#: chat_action.py:192
#, python-brace-format
msgid ""
"{label} não tem uma API key configurada.\n"
"\n"
"Defina-a em {config_path} (chave 'providers.{provider_id}.api_key') ou na"
" variável de ambiente correspondente, e volte a selecionar o provider."
